VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0" // Язык: English (US), Кодировка: Unicode
        BEGIN
            VALUE "CompanyName", "Home"
            VALUE "FileDescription", "Scientific formula calculator"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "Fcalc"
            VALUE "LegalCopyright", "Copyright (C) 2026 Home"
            VALUE "OriginalFilename", "fcalc.exe"
            VALUE "ProductName", "Scientific formula calculator"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200 // 1200 - это Unicode
    END
END